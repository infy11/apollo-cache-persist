{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "pretty": true,
    "noImplicitAny": true,
    "noUnusedParameters": false,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "removeComments": true,
    "sourceMap": true,
    "declaration": true,
    "target": "es2020",
    "module": "ESNext",
    "esModuleInterop": true,
    "lib": [
      "ES2020"
    ],
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/*.ts",
    "src/**/__mocks__/*.ts",
    "node_modules",
    "examples/**/*"
  ]
}