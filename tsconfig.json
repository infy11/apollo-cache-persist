{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "pretty": true,
    "noImplicitAny": true,
    "noUnusedParameters": false,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "removeComments": true,
    "sourceMap": true,
    "declaration": true,
    "target": "es2020",
    "module": "nodenext",
    "lib": [
      "es2020"
    ],
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/*.ts",
    "src/**/__mocks__/*.ts",
    "node_modules"
  ]
}